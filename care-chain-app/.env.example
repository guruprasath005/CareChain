# Copy to `.env` in this folder (care-chain-app). Restart Expo (`npx expo start --clear`).

# ── Reliable auth on a real phone (same as working Documents/Care-Chain setup) ──
# Uncomment to always hit hosted HTTPS (works in Expo Go on iPhone):
# EXPO_PUBLIC_API_URL=https://care-chain-backend.onrender.com/api/v1

# ── Local backend (Mac + same Wi‑Fi) ──
# Use LAN IP; backend PORT must be 5001 (5000 is AirPlay on macOS).
# EXPO_PUBLIC_API_URL=http://192.168.1.XXX:5001/api/v1

# `/api/v1` is added automatically if you omit it.

# If you insist on LAN http in Expo Go on iOS (usually still blocked by iOS):
# EXPO_PUBLIC_ALLOW_LAN_HTTP=true
