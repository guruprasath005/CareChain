# ============================================================
# CareChain Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in every value before starting.
# Lines beginning with # are comments.
# Never commit the real .env file to source control.

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development            # development | test | production
# Default 5001 — macOS uses port 5000 for AirPlay Receiver (AirTunes). If you use 5000, curl hits Apple, not Node (403, empty body, Server: AirTunes).
PORT=5001
API_VERSION=v1
API_PREFIX=/api/v1

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
# Option 1 — Use DATABASE_URL (Render / Heroku / Neon / Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/carechain?sslmode=require

# Option 2 — Individual variables (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carechain
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Schema sync — NEVER set to true in production (use migrations instead)
# DB_SYNC=true

# ============================================================
# REDIS
# ============================================================
# Option 1 — Redis URL (Upstash / Redis Cloud / Render)
# REDIS_URL=redis://:password@host:6379

# Option 2 — Individual variables
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_THIS_to_a_64_char_random_hex_string
JWT_REFRESH_SECRET=CHANGE_THIS_to_a_different_64_char_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# OTP CONFIGURATION
# ============================================================
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# ============================================================
# EMAIL (SMTP — Brevo recommended)
# ============================================================
# Get your API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false            # true for port 465
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM_EMAIL=noreply@carechain.in
SMTP_FROM_NAME=CareChain

# ============================================================
# FILE UPLOAD
# ============================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
# Comma-separated MIME types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================================
# CLOUDINARY (Cloud file storage — optional, replaces local uploads)
# ============================================================
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_UPLOAD_PRESET=care_chain_uploads

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX_REQUESTS=500

# ============================================================
# APP / EMAIL LINKS
# ============================================================
# Used in transactional emails when CORS allows many origins (e.g. dev)
APP_PUBLIC_URL=http://localhost:3000

# ============================================================
# CORS
# ============================================================
# Production: set explicit origins (comma-separated), e.g. your web app + Expo dev:
#   CORS_ORIGIN=https://app.example.com,http://localhost:8081
# Leave unset in development → server reflects any Origin (Expo Go on a phone, LAN IP, etc.)
# Use * only if CORS_CREDENTIALS=false (cookies + * are incompatible in browsers)
# CORS_ORIGIN=http://localhost:3000,http://localhost:8081
CORS_CREDENTIALS=true

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug               # error | warn | info | http | debug
LOG_FORMAT=combined

# ============================================================
# API GATEWAY
# ============================================================
GATEWAY_RATE_LIMITING=true
GATEWAY_CIRCUIT_BREAKER=true
GATEWAY_CACHING=true
GATEWAY_REQUEST_QUEUE=true

# ============================================================
# JOB QUEUE (BullMQ)
# ============================================================
QUEUE_CONCURRENCY=50
QUEUE_BULK_BATCH_SIZE=100
QUEUE_MAX_RETRIES=3

# ============================================================
# NOTIFICATIONS
# ============================================================
# Batch window in ms — notifications for the same user collected in this window
# are delivered together (default 15 s)
NOTIFICATION_BATCH_DELAY_MS=15000

# ============================================================
# RAZORPAY PAYMENT GATEWAY
# ============================================================
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Set to 'true' to require hospitals to purchase credits before posting jobs
REQUIRE_JOB_POST_CREDITS=false

# ============================================================
# FIREBASE (Push Notifications — optional)
# ============================================================
# Download service-account JSON from Firebase Console → Project Settings → Service Accounts
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com

# ============================================================
# CLUSTER MODE (Horizontal scaling — optional)
# ============================================================
# CLUSTER_ENABLED=false
# CLUSTER_WORKERS=0            # 0 = auto-detect CPU count
# CLUSTER_RESTART_ON_EXIT=true
# CLUSTER_SHUTDOWN_TIMEOUT=30000

# ============================================================
# REDIS CLUSTER (Production Redis cluster — optional)
# ============================================================
# Comma-separated "host:port" pairs; leave blank to use single-node Redis above
# REDIS_CLUSTER_NODES=node1:7000,node2:7001,node3:7002

# ============================================================
# AADHAAR VERIFICATION (Future integration)
# ============================================================
# AADHAAR_API_KEY=
# AADHAAR_API_URL=
