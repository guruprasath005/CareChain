# CareChain Backend Scalability Configuration
# Add these to your .env file

# =====================================
# REDIS CONFIGURATION
# =====================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# For Redis Cluster (production)
# REDIS_CLUSTER_NODES=host1:6379,host2:6379,host3:6379

# =====================================
# CLUSTER MODE (Multi-process)
# =====================================
# Enable to run multiple worker processes
CLUSTER_ENABLED=false
# Number of workers (0 = auto, based on CPU count)
CLUSTER_WORKERS=0
# Restart workers on crash
CLUSTER_RESTART_ON_EXIT=true
# Timeout for graceful shutdown (ms)
CLUSTER_SHUTDOWN_TIMEOUT=30000

# =====================================
# API GATEWAY
# =====================================
# Enable/disable gateway features
GATEWAY_RATE_LIMITING=true
GATEWAY_CIRCUIT_BREAKER=true
GATEWAY_CACHING=true
GATEWAY_REQUEST_QUEUE=true

# =====================================
# RATE LIMITING
# =====================================
# General rate limit window (ms)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# =====================================
# JOB QUEUE
# =====================================
# Concurrent job processing
QUEUE_CONCURRENCY=50
# Batch size for bulk operations
QUEUE_BULK_BATCH_SIZE=100
# Max retry attempts for failed jobs
QUEUE_MAX_RETRIES=3

# =====================================
# DATABASE POOL (PostgreSQL)
# =====================================
# Minimum connections in pool
DB_POOL_MIN=5
# Maximum connections in pool
DB_POOL_MAX=50

# =====================================
# PERFORMANCE TUNING
# =====================================
# Node.js memory limit (increase for heavy load)
# NODE_OPTIONS=--max-old-space-size=4096
