# Django Settings
SECRET_KEY=your-super-secret-key-change-me
DEBUG=1
# For local dev, add your ngrok domain here (without https://)
ALLOWED_HOSTS_EXTRA=web,your-ngrok-domain.ngrok-free.app
SITE_DOMAIN=your-ngrok-domain.ngrok-free.app

# Postgres Settings
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword

# Telegram & Bot Settings
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
BOT_API_KEY=your-generated-secret-api-key

# Superuser Credentials for Automated Setup (can be changed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=strongpassword123
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
